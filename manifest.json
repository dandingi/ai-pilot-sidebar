{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "description": "__MSG_appDescription__",
  "version": "0.1.0",
  "default_locale": "zh_CN",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://grok.com/*",
    "https://*.grok.com/*",
    "https://grok.x.ai/*",
    "https://*.grok.x.ai/*",
    "https://gemini.google.com/*",
    "https://*.gemini.google.com/*",
    "https://www.doubao.com/*",
    "https://*.doubao.com/*",
    "https://kimi.moonshot.cn/*",
    "https://*.kimi.moonshot.cn/*",
    "https://claude.ai/*",
    "https://*.claude.ai/*",
    "https://chat.deepseek.com/*",
    "https://*.deepseek.com/*",
    "https://copilot.microsoft.com/*",
    "https://*.copilot.microsoft.com/*"
  ],
  "action": {
    "default_title": "__MSG_appName__",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://grok.com/*",
        "https://*.grok.com/*",
        "https://grok.x.ai/*",
        "https://*.grok.x.ai/*",
        "https://gemini.google.com/*",
        "https://*.gemini.google.com/*",
        "https://www.doubao.com/*",
        "https://*.doubao.com/*",
        "https://kimi.moonshot.cn/*",
        "https://*.kimi.moonshot.cn/*",
        "https://claude.ai/*",
        "https://*.claude.ai/*",
        "https://chat.deepseek.com/*",
        "https://*.deepseek.com/*",
        "https://copilot.microsoft.com/*",
        "https://*.copilot.microsoft.com/*"
      ],
      "js": [
        "src/ai-frame-cleaner.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "commands": {
    "toggle-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "__MSG_commandToggleSidePanel__"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' https: data:; frame-src https://*;"
  }
}
